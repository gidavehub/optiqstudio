rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Generated media is served through tokenized download URLs created by
    // the server, so direct client access stays locked down.
    match /generations/{uid}/{file} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow write: if false;
    }
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
