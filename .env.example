# ── Google Cloud / Vertex AI ────────────────────────────────────────────────
GOOGLE_CLOUD_PROJECT=davelabs-tools
VERTEX_LOCATION=us-east4
# Pass the contents of your Google Cloud service account JSON file as a string
# (Useful for production environments like Vercel):
# GCP_SERVICE_ACCOUNT_KEY='{"type": "service_account", ...}'


# Model overrides (defaults live in lib/vertex.ts)
# VEO_MODEL_ID=gemini-omni-flash-preview
# IMAGE_MODEL_ID=gemini-3.1-flash-image-preview

# ── ModemPay ────────────────────────────────────────────────────────────────
MODEM_PAY_API_KEY=your_modem_pay_live_secret_key_here
NEXT_PUBLIC_MODEM_PAY_PUBLIC_KEY=your_modem_pay_live_public_key_here
MODEM_PAY_MERCHANT_ID=your_modem_pay_merchant_id_here

# Get this from ModemPay dashboard → Developers → Webhooks after registering
# https://us-east4-davelabs-tools.cloudfunctions.net/modemWebhook or your production URL
MODEM_WEBHOOK_SECRET=your_modem_pay_webhook_signing_secret_here

PAYMENT_CURRENCY=USD

# ── App ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
